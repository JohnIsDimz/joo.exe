<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE000000">

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/kids_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Lock Icon -->
        <TextView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/kids_btn_sos"
            android:gravity="center"
            android:drawableStart="@drawable/ic_lock" android:text=""
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Layar Terkunci"
            android:textColor="@color/kids_red"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lockReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Screen time habis"
            android:textAlignment="center"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/lockMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Minta orang tua untuk buka"
            android:textAlignment="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Space android:layout_width="match_parent" android:layout_height="16dp" />

        <Button
            android:id="@+id/btnOverlayUnlock"
            style="@style/KidsButton.Secondary"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="MINTA BUKA" />

    </LinearLayout>

</FrameLayout>

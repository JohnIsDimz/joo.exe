<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KidsFamily" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/neon_magenta</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Keep existing styles for overlay_screen_lock -->
    <style name="KidsButton" parent="Widget.AppCompat.Button">
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:background">@drawable/kids_btn_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="KidsButton.Secondary">
        <item name="android:background">@drawable/kids_btn_secondary</item>
        <item name="android:textColor">@color/black</item>
    </style>
    <style name="KidsButton.SOS">
        <item name="android:background">@drawable/kids_btn_sos</item>
    </style>
    <style name="KidsCard">
        <item name="android:background">@drawable/kids_card</item>
        <item name="android:padding">16dp</item>
    </style>
    <style name="KidsInput" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/kids_input</item>
        <item name="android:padding">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_dim</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>

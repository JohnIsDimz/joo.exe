<?xml version="1.0" encoding="utf-8"?>
<!-- KidsFamily - Fun auth screen for kids -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_kids_gradient"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- Main Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_kids_card"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo -->
        <TextView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_kids_gradient"
            android:gravity="center"
            android:text="KF"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="KidsFamily"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:text="Kids App"
            android:textColor="#FF7C4DFF"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textStyle="bold" />

        <!-- Error -->
        <TextView
            android:id="@+id/errorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1AFFE53935"
            android:gravity="center"
            android:padding="10dp"
            android:textColor="@color/error"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Nama -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Panggilan"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/inputName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_kids_input"
            android:padding="14dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:hint="Your name"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/inputEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_kids_input"
            android:padding="14dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            android:hint="Your email"
            android:inputType="textEmailAddress"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />

        <!-- Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp">
            <EditText
                android:id="@+id/inputPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_kids_input"
                android:padding="14dp"
                android:paddingEnd="52dp"
                android:hint="Password"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/togglePass"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:gravity="center"
                android:drawableStart="@drawable/ic_eye" android:drawablePadding="8dp" android:text="" android:contentDescription="Show password"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true" />
        </FrameLayout>

        <!-- Family Code -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kode Keluarga"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/inputFamilyCode"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_kids_input"
            android:padding="14dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="22dp"
            android:hint="Dari orang tua"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />

        <!-- Daftar Button -->
        <Button
            android:id="@+id/btnJoin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_kids_btn"
            android:text="Join Family"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="15sp"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Get the code from your parents"
        android:textColor="#DDFFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

</LinearLayout>

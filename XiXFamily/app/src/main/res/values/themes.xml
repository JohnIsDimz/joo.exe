<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- CYBERPUNK RGB NEON THEME -->
    <style name="Theme.XiXFamily" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/neon_magenta</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/neon_cyan</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.XiXFamily.Splash" parent="Theme.XiXFamily">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>

    <!-- Feature Button Neon Style -->
    <style name="FeatureBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:paddingLeft">4dp</item>
        <item name="android:paddingRight">4dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_feature_btn</item>
        <item name="android:lines">2</item>
    </style>
</resources>
